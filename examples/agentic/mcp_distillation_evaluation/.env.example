# MCP Evaluation Benchmark — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Model configuration (optional — defaults shown) ──────────────────
# TEACHER_MODEL=openai/gpt-5.2
# JUDGE_MODEL=openai/gpt-4o

# ── Only needed for task generation (Section 2) ──────────────────────
# Skip these if using the pre-generated tasks in outputs/
# Each LangGraph agent should be connected to one MCP server.
# Deploy with: langgraph dev --port <port>
LANGGRAPH_URL_WEATHER_DATA=http://localhost:2024
LANGGRAPH_URL_MEDICAL_CALCULATOR=http://localhost:2025
LANGGRAPH_URL_WIKIPEDIA=http://localhost:2026
LANGGRAPH_URL_CAR_PRICE=http://localhost:2027
LANGGRAPH_URL_REDDIT=http://localhost:2028
LANGGRAPH_URL_DEX_PAPRIKA=http://localhost:2029

# LangGraph API key for authentication (if required by your deployment)
# LANGGRAPH_API_KEY=
